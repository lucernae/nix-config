export NIXPKGS_ALLOW_UNFREE=1

# Model configuration
export MODEL_REPO="unsloth/Qwen3.5-35B-A3B-GGUF"
export MODEL_NAME="Qwen3.5-35B-A3B"
export QUANTIZATION="UD-IQ2_XXS"

# Backend selection
# export USE_OLLAMA=1  # Uncomment to use Ollama instead of llama.cpp

# Model storage
export OLLAMA_MODELS=/var/llm-models/.ollama/models

use flake . --impure
source .venv/bin/activate
source_env_if_exists .local.envrc